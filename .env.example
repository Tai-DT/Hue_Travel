# ============================================
# Huế Travel — Environment Variables
# ============================================
# Copy to .env and fill in values
# ============================================

# ---- App ----
APP_ENV=development
APP_PORT=8080
APP_NAME=hue-travel-api
APP_URL=http://localhost:8080
APP_STRICT_MODE=false
# Optional in development. Leave unset to use env-based defaults.
# ALLOW_MOCK_SERVICES=true
DEV_FIXED_OTP=123456
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:19006

# ---- Database ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hue_travel
POSTGRES_USER=huetravel
POSTGRES_PASSWORD=huetravel_dev_2026
DATABASE_URL=postgres://huetravel:huetravel_dev_2026@localhost:5432/hue_travel?sslmode=disable

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- MinIO (S3) ----
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=huetravel
MINIO_ROOT_PASSWORD=huetravel_minio_2026
MINIO_BUCKET=hue-travel
MINIO_USE_SSL=false

# ---- Meilisearch ----
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=huetravel_meili_dev_key
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=huetravel_meili_dev_key

# ---- JWT ----
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=720h

# ---- Goong Maps ----
GOONG_API_KEY=

# ---- Google Gemini ----
GEMINI_API_KEY=

# ---- Payment: VNPay ----
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_BASE_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8080/api/v1/payment/vnpay/return
VNPAY_IPN_URL=http://localhost:8080/api/v1/payment/vnpay/ipn

# ---- Payment: MoMo ----
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_BASE_URL=https://test-payment.momo.vn/v2/gateway/api

# ---- SMS: ESMS ----
ESMS_API_KEY=
ESMS_SECRET_KEY=
ESMS_BRAND_NAME=HueTravel
ESMS_BRANDNAME=HueTravel

# ---- Firebase ----
FIREBASE_CREDENTIALS_FILE=./firebase-credentials.json
FCM_SERVER_KEY=

# ---- Email ----
RESEND_API_KEY=

# ---- Weather ----
OPENWEATHER_API_KEY=

# ---- OAuth ----
# Comma-separated list of accepted Google OAuth client IDs
GOOGLE_CLIENT_IDS=
# Fallback single Google client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ---- Expo / Mobile ----
EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
