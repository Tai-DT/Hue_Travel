# ============================================
# Huế Travel — Production Environment Variables
# Copy this to .env in deploy/ directory
# ============================================

# ---- Database ----
POSTGRES_DB=hue_travel
POSTGRES_USER=huetravel
POSTGRES_PASSWORD=your_secure_password_here

# ---- JWT ----
JWT_SECRET=your_jwt_secret_minimum_32_chars_here

# ---- MinIO (S3 Storage) ----
MINIO_ROOT_USER=huetravel
MINIO_ROOT_PASSWORD=your_minio_password_here

# ---- Meilisearch ----
MEILISEARCH_MASTER_KEY=your_meilisearch_key_here

# ---- Firebase FCM ----
FCM_SERVER_KEY=your_fcm_server_key_here

# ---- ESMS.vn SMS ----
ESMS_API_KEY=your_esms_api_key
ESMS_SECRET_KEY=your_esms_secret_key
ESMS_BRAND_NAME=HueTravel

# ---- VNPay ----
VNPAY_TMN_CODE=DEMO
VNPAY_HASH_SECRET=your_vnpay_hash_secret

# ---- Google ----
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_MAPS_API_KEY=your_maps_api_key
